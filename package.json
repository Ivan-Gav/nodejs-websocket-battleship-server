{
  "name": "ws_battleship",
  "version": "1.0.0",
  "description": "Websockets Battleship task for RSScholl Node.js course 2025",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/index.js",
    "start:front": "node src/http_server/index.js",
    "start:dev": "nodemon --watch src --ext ts --exec \"node --no-warnings --loader ts-node/esm src/index.ts\"",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [],
  "license": "ISC",
  "dependencies": {
    "dotenv": "^16.5.0",
    "ws": "^8.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}
